{
    "extends": [
        "config:recommended"
    ],
    "gitIgnoredAuthors": [
        "github-actions[bot]@users.noreply.github.com",
        "41898282+github-actions[bot]@users.noreply.github.com"
    ],
    "platformAutomerge": true,
    "rebaseWhen": "behind-base-branch",
    "semanticCommits": "disabled",
    "enabledManagers": [
        "github-actions",
        "helm-values",
        "helmv3",
        "custom.regex"
    ],
    "pinDigests": true,
    "prHourlyLimit": 5,
    "prConcurrentLimit": 3,
    "timezone": "Europe/Berlin",
    "assignees": [
        "slydlake"
    ],
    "customManagers": [
        {
            "customType": "regex",
            "description": "Update tag in values.yaml for linuxserver/wireguard",
            "fileMatch": [
                "^charts/wireguard/values\\.yaml$"
            ],
            "matchStrings": [
                "repository:\\s+linuxserver/wireguard[\\s\\S]*?tag:\\s+['\"]?(?<currentValue>[^'\"\\s@]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
            ],
            "depNameTemplate": "docker.io/linuxserver/wireguard",
            "datasourceTemplate": "docker"
        },
        {
            "customType": "regex",
            "description": "Update appVersion in Chart.yaml",
            "fileMatch": [
                "^charts/.*/Chart\\.yaml$"
            ],
            "matchStrings": [
                "appVersion:\\s+['\"]?(?<currentValue>[^'\"\\s]+)['\"]?\\s*#\\s*renovate:\\s*image=(?<packageName>[^\\s]+)"
            ],
            "depNameTemplate": "{{{packageName}}}",
            "datasourceTemplate": "docker"
        },
        {
            "customType": "regex",
            "description": "Update artifacthub.io/images in Chart.yaml",
            "fileMatch": [
                "^charts/.*/Chart\\.yaml$"
            ],
            "matchStrings": [
                "image: (?<packageName>[^:]+):(?<currentValue>[^\\s]+)"
            ],
            "depNameTemplate": "{{{packageName}}}",
            "datasourceTemplate": "docker"
        }
    ],
    "packageRules": [
        {
            "description": "Disable helm-values for wireguard (handled by custom.regex)",
            "matchManagers": [
                "helm-values"
            ],
            "matchFileNames": [
                "charts/wireguard/values.yaml"
            ],
            "matchPackageNames": [
                "docker.io/linuxserver/wireguard"
            ],
            "enabled": false
        },
        {
            "description": "Wireguard regex versioning override",
            "matchManagers": [
                "custom.regex"
            ],
            "matchFileNames": [
                "charts/wireguard/values.yaml",
                "charts/wireguard/Chart.yaml"
            ],
            "matchPackageNames": [
                "docker.io/linuxserver/wireguard"
            ],
            "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-r(?<prerelease>\\d+)-ls(?<build>\\d+)$"
        },
        {
            "description": "Group all updates per chart into one PR with consistent labels and commit messages",
            "matchManagers": [
                "helm-values",
                "custom.regex"
            ],
            "matchFileNames": [
                "charts/**"
            ],
            "groupName": "chart/{{{ replace '/samples' '' (replace 'charts/' '' parentDir) }}}",
            "labels": [
                "dependencies",
                "renovate"
            ],
            "addLabels": [
                "{{#if isMajor}}major{{/if}}{{#if isMinor}}minor{{/if}}{{#if isPatch}}patch{{/if}}{{#if isDigest}}digest{{/if}}"
            ],
            "semanticCommits": "disabled",
            "commitMessagePrefix": "",
            "commitMessageAction": "charts/{{{ replace '/samples' '' (replace 'charts/' '' parentDir) }}} chore(deps): updates",
            "commitMessageTopic": "",
            "commitMessageExtra": ""
        },
        {
            "description": "Group subchart updates per chart with consistent labels and commit messages",
            "matchManagers": [
                "helmv3"
            ],
            "matchFileNames": [
                "charts/**"
            ],
            "groupName": "subchart/{{{ replace '/samples' '' (replace 'charts/' '' parentDir) }}}",
            "labels": [
                "dependencies",
                "renovate"
            ],
            "addLabels": [
                "{{#if isMajor}}major{{/if}}{{#if isMinor}}minor{{/if}}{{#if isPatch}}patch{{/if}}{{#if isDigest}}digest{{/if}}"
            ],
            "semanticCommits": "disabled",
            "commitMessagePrefix": "",
            "commitMessageAction": "charts/{{{ replace '/samples' '' (replace 'charts/' '' parentDir) }}} chore(deps): subchart updates",
            "commitMessageTopic": "",
            "commitMessageExtra": ""
        },
        {
            "description": "Group wordpress subchart updates per dependency to avoid long-lived grouped PRs",
            "matchManagers": [
                "helmv3"
            ],
            "matchFileNames": [
                "charts/wordpress/**"
            ],
            "groupName": "subchart/wordpress/{{{depName}}}",
            "labels": [
                "dependencies",
                "renovate"
            ],
            "addLabels": [
                "{{#if isMajor}}major{{/if}}{{#if isMinor}}minor{{/if}}{{#if isPatch}}patch{{/if}}{{#if isDigest}}digest{{/if}}"
            ],
            "semanticCommits": "disabled",
            "commitMessagePrefix": "",
            "commitMessageAction": "charts/wordpress chore(deps): update {{{depName}}}",
            "commitMessageTopic": "",
            "commitMessageExtra": ""
        },
        {
            "description": "Label direct dependency minor updates for chart minor bumps",
            "matchManagers": [
                "helm-values",
                "custom.regex"
            ],
            "matchUpdateTypes": [
                "minor"
            ],
            "addLabels": [
                "chart-bump-minor",
                "direct-dependency-update"
            ]
        },
        {
            "description": "Label direct dependency patch and digest updates for chart patch bumps",
            "matchManagers": [
                "helm-values",
                "custom.regex"
            ],
            "matchUpdateTypes": [
                "patch",
                "digest"
            ],
            "addLabels": [
                "chart-bump-patch",
                "direct-dependency-update"
            ]
        },
        {
            "description": "Label direct dependency major updates",
            "matchManagers": [
                "helm-values",
                "custom.regex"
            ],
            "matchUpdateTypes": [
                "major"
            ],
            "addLabels": [
                "chart-bump-major",
                "direct-dependency-update"
            ]
        },
        {
            "description": "Label subchart non-major updates for chart patch bumps",
            "matchManagers": [
                "helmv3"
            ],
            "matchUpdateTypes": [
                "minor",
                "patch",
                "digest"
            ],
            "addLabels": [
                "chart-bump-patch",
                "subchart-update"
            ]
        },
        {
            "description": "Label subchart major updates",
            "matchManagers": [
                "helmv3"
            ],
            "matchUpdateTypes": [
                "major"
            ],
            "addLabels": [
                "chart-bump-major",
                "subchart-update"
            ]
        },
        {
            "description": "Group GitHub Actions workflow updates into one PR with consistent labels and commit messages",
            "matchManagers": [
                "github-actions"
            ],
            "matchFileNames": [
                ".github/workflows/**"
            ],
            "groupName": "github-actions/workflows",
            "labels": [
                "dependencies",
                "renovate"
            ],
            "addLabels": [
                "{{#if isMajor}}major{{/if}}{{#if isMinor}}minor{{/if}}{{#if isPatch}}patch{{/if}}{{#if isDigest}}digest{{/if}}"
            ],
            "semanticCommits": "disabled",
            "commitMessagePrefix": "",
            "commitMessageAction": "github workflows chore(deps): updates",
            "commitMessageTopic": "",
            "commitMessageExtra": ""
        },
        {
            "description": "Auto-merge minor, patch, and digest updates",
            "matchManagers": [
                "github-actions",
                "helm-values",
                "custom.regex",
                "helmv3"
            ],
            "matchUpdateTypes": [
                "minor",
                "patch",
                "digest"
            ],
            "addLabels": [
                "automerge"
            ],
            "automerge": true,
            "automergeType": "pr"
        },
        {
            "description": "Never auto-merge major updates",
            "matchManagers": [
                "github-actions",
                "helm-values",
                "custom.regex",
                "helmv3"
            ],
            "matchUpdateTypes": [
                "major"
            ],
            "addLabels": [
                "major"
            ],
            "automerge": false
        }
    ]
}